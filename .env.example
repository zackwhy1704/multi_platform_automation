# =============================================================================
# Multi-Platform Automation Bot — Environment Variables
# Copy this to .env and fill in your values
# =============================================================================

# --- Domain (for Caddy auto-HTTPS) ---
DOMAIN=bot.yourdomain.com

# --- Database (PostgreSQL) ---
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_NAME=multi_platform_bot
DATABASE_USER=postgres
DATABASE_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- WhatsApp Cloud API ---
# Get these from Meta Developer Console → WhatsApp → API Setup
WHATSAPP_TOKEN=your_whatsapp_permanent_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=my_custom_verify_token
WHATSAPP_APP_SECRET=your_app_secret
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id

# --- Stripe ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# --- Payment Server ---
PAYMENT_SERVER_URL=https://bot.yourdomain.com

# --- AI (Anthropic Claude) ---
ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL=claude-haiku-4-5-20251001

# --- Encryption (generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())") ---
ENCRYPTION_KEY=your_fernet_key_here

# --- Credits ---
MONTHLY_CREDITS=500
CREDIT_COST_POST=5
CREDIT_COST_REPLY=3

# --- Facebook Graph API (optional, users provide their own tokens) ---
FB_APP_ID=
FB_APP_SECRET=

# --- Instagram Graph API (optional) ---
IG_APP_ID=
IG_APP_SECRET=

# --- Admin ---
ADMIN_PHONE_NUMBERS=60123456789,60198765432

# --- Celery (for testing) ---
CELERY_ALWAYS_EAGER=False
